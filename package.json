{
  "name": "ecom-ruq",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "dev": "next dev -p 5001",
    "build": "next build",
    "start": "next start -p 5001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed:dev": "tsx scripts/seed-dev-tenant.ts",
    "test:db": "vitest run tests/unit/db/",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f",
    "services:reset": "docker compose down -v && docker compose up -d",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium webkit",
    "check:e2e-coverage": "tsx scripts/check-e2e-coverage.ts",
    "lhci": "lhci autorun --config=./lighthouserc.cjs"
  },
  "dependencies": {
    "better-auth": "1.6.5",
    "canonicalize": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "5.10.1",
    "next": "^15.1.0",
    "next-intl": "^4.9.1",
    "nodemailer": "8.0.5",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
