# Anthropic Claude API (required)
ANTHROPIC_API_KEY=

# Database — four connection strings, one per Postgres role.
# Local dev can point all four at the same superuser DSN; staging/prod must use
# separate roles (app_migrator, app_user, app_tenant_lookup + a dedicated Better
# Auth role — see migrations/0001).
#
#   DATABASE_URL              — migrator, used only by `pnpm db:migrate`.
#   DATABASE_URL_APP          — runtime pool for the app (role: app_user).
#                               All tenant-scoped work runs inside withTenant(...).
#   DATABASE_URL_BA           — dedicated pool for Better Auth writes. MUST NOT
#                               connect as app_user (RLS would silently filter
#                               BA's writes). In dev, falls back to DATABASE_URL_APP.
#                               Chunk 10 boot guard refuses to start in real
#                               production if this resolves to app_user.
#   DATABASE_URL_TENANT_LOOKUP — read-only pool for tenant resolution middleware.
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ecom_ruq_dev
DATABASE_URL_APP=postgresql://postgres:postgres@localhost:55432/ecom_ruq_dev
DATABASE_URL_BA=
DATABASE_URL_TENANT_LOOKUP=postgresql://postgres:postgres@localhost:55432/ecom_ruq_dev

# Envelope encryption (Tier-A identity data).
# Generate with: openssl rand -base64 32
# Must be exactly 32 bytes after base64 decode. Refuse to boot if unset,
# malformed, all-zeros, or matches a known dev placeholder pattern.
DATA_KEK_BASE64=

# PAT token hash pepper. HMAC-SHA-256(pepper, token_plaintext).
# Generate with: openssl rand -base64 32
TOKEN_HASH_PEPPER=

# Audit hash pepper. Keyed HMAC-SHA-256 over canonical-JSON (RFC 8785) audit
# payloads and the per-tenant row_hash chain. DISTINCT from TOKEN_HASH_PEPPER:
# different threat models (tokens: offline brute-force of high-entropy secrets;
# audit: confirmation attacks against known-enumerable PII fields). Reusing the
# same pepper would weaken both.
# Generate with: openssl rand -base64 32
HASH_PEPPER=

# Redis (Docker Compose: on host port 56379)
REDIS_URL=redis://localhost:56379

# Meilisearch (Docker Compose: on host port 57700)
MEILI_HOST=http://localhost:57700
MEILI_MASTER_KEY=dev_master_key_change_me

# Mailpit SMTP for local dev (Docker Compose: SMTP 51025, Web UI http://localhost:58025)
SMTP_HOST=localhost
SMTP_PORT=51025

# Mailpit HTTP API (Playwright helpers poll this during e2e flows that send email)
MAILPIT_URL=http://localhost:58025

# Sentry (optional locally; required before staging)
SENTRY_DSN=

# Better Auth (generate a random 32-byte secret for each env)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5001

# Dev-only. Set to 1 to allow resolveTenant to return a fallback tenant on
# unknown hosts. Leave UNSET in any non-local environment — the resolver
# unconditionally returns null in production regardless of this flag.
ALLOW_TENANT_FALLBACK=

# Image storage backend (chunk 1a.7.1).
#
#   IMAGE_STORAGE_BACKEND   — "local" (default) or "bunny".
#   IMAGE_STORAGE_LOCAL_DIR — root dir for "local" backend.
#                             Default: .storage/images (relative to cwd).
#                             Stays under .gitignore.
#
# When IMAGE_STORAGE_BACKEND=bunny, ALL THREE bunny vars must be set or
# the app refuses to start. The AccessKey is sent on every Bunny request
# and must NEVER be logged or echoed back to clients.
IMAGE_STORAGE_BACKEND=local
IMAGE_STORAGE_LOCAL_DIR=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_PASSWORD=
